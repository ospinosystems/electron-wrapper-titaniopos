# Copiar a .env y rellenar (no subir .env al repo)

# URL de la PWA que abre Electron (producción o local)
TITANIOPOS_URL=http://localhost:3001

# Misma clave que uses en el backend/frontend para JWT de respaldos, etc.
TITANIOPOS_JWT_SECRET=

# Solo si publicas desde tu PC: npm run release
# Con GitHub Actions + tags no hace falta en .env
GH_TOKEN=

# Release por tag (recomendado): git tag v1.0.1 && git push origin v1.0.1
# Enlaces al último build (tras publicar un release):
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Setup.exe
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Portable.exe

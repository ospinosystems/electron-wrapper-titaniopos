# Copiar a .env y ajustar valores (app en runtime)
TITANIOPOS_URL=http://localhost:3001
TITANIOPOS_JWT_SECRET=

# --- Subir el instalador a GitHub (forma práctica) ---
# Usa GitHub Actions: pestaña Actions → "Release Windows" → Run workflow.
# Antes sube un bump de "version" en package.json y haz push. No hace falta GH_TOKEN aquí.
#
# Solo si publicas desde TU PC con: npm run release
# GH_TOKEN=ghp_xxxxxxxx   # PAT con permiso repo

# Enlace fijo al último instalador (después del primer release):
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Setup.exe
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Portable.exe
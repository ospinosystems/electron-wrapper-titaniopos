# Copiar a .env y rellenar (no subir .env al repo)

# URL de la PWA que abre Electron (producción o local)
TITANIOPOS_URL=https://frontend.titanio-pos.com/login

# Misma clave que uses en el backend/frontend para JWT de respaldos, etc.
TITANIOPOS_JWT_SECRET=

# --- Build con tag en GitHub Actions ---
# Repo → Settings → Secrets and variables → Actions
#   Variable (tab Variables):  TITANIOPOS_URL   → URL de producción del frontend
#   Secret (tab Secrets): TITANIOPOS_JWT_SECRET
# El workflow crea .env antes de npm run release; no subas .env al git.
# Si no defines TITANIOPOS_URL en Variables, el build usa http://localhost:3001
# (así en el instalador ves si faltó configurar GitHub).

# Solo si publicas desde tu PC: npm run release
GH_TOKEN=



# Actualizaciones dentro de la app (electron-updater): el repo de releases en GitHub
# debe ser público O los .yml/.exe deben ser descargables sin token. Si el repo es
# privado, verás error 404 al buscar actualizaciones desde el instalador.

# Release por tag (recomendado): git tag v1.0.1 && git push origin v1.0.1
# Enlaces al último build (tras publicar un release):
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Setup.exe
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Portable.exe
#git tag v1.0.0
#git push origin v1.0.0
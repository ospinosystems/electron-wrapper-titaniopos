# Copiar a .env y ajustar valores
TITANIOPOS_URL=http://localhost:3001
TITANIOPOS_JWT_SECRET=

# Publicar instalador a GitHub Releases (npm run release):
# Crear token en GitHub → Settings → Developer settings → PAT, scope "repo".
# GH_TOKEN=ghp_xxxxxxxx

# Primera instalación por enlace (sin pendrive), tras subir un release:
# Instalador NSIS (recomendado):
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Setup.exe
# Portable (sin instalador):
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Portable.exe
# Listado de versiones:
# https://github.com/ospinosystems/electron-wrapper-titaniopos/releases

# =============================================================================
# TitanioPOS Desktop (Electron) — environment template
# =============================================================================
# Copy this file to `.env` in the same folder as the app (project root in dev,
# or next to the packaged executable when you ship a custom .env).
# Never commit real `.env` files or secrets to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend URL
# -----------------------------------------------------------------------------
# Full URL of the web app Electron loads (production or local dev server).
# If empty, the app falls back to http://localhost:3001
TITANIOPOS_URL=https://your-frontend.example.com/login

# -----------------------------------------------------------------------------
# JWT secret
# -----------------------------------------------------------------------------
# Used by the desktop app to sign/verify embedded backup payloads.
# Use the same secret as your backend/frontend stack if they must interoperate.
TITANIOPOS_JWT_SECRET=

# -----------------------------------------------------------------------------
# Developer Tools (Chromium DevTools)
# -----------------------------------------------------------------------------
# When true (1, true, yes, on — case-insensitive), DevTools open on startup and
# all shortcuts / menu actions open DevTools without a password.
# When false or unset, opening DevTools requires TITANIOPOS_DEVTOOLS_PASSWORD.
TITANIOPOS_OPEN_DEVTOOLS_ON_START=false

# Required only when TITANIOPOS_OPEN_DEVTOOLS_ON_START is not enabled.
# Plain text; use a strong value in production POS deployments.
TITANIOPOS_DEVTOOLS_PASSWORD=

# -----------------------------------------------------------------------------
# Fiscal bridge (optional)
# -----------------------------------------------------------------------------
# TCP port for the bundled fiscal Python service (default 3000 if unset).
# FISCAL_SERVER_PORT=3000

# Path to INTFHKA / fiscal DLL tooling on the machine (optional).
# INTFHKA_PATH=

# -----------------------------------------------------------------------------
# Local releases from your machine (optional)
# -----------------------------------------------------------------------------
# Personal access token with repo scope, only if you run `npm run release`
# locally to publish to GitHub. CI uses GITHUB_TOKEN instead.
GH_TOKEN=

# -----------------------------------------------------------------------------
# GitHub Actions (release workflow)
# -----------------------------------------------------------------------------
# Repository → Settings → Secrets and variables → Actions
#
# Variables (not secret):
#   TITANIOPOS_URL — production frontend URL embedded in the installer.
#   TITANIOPOS_OPEN_DEVTOOLS_ON_START — optional; true/false. If unset, the
#     workflow writes false (recommended for store-facing builds).
#
# Secrets:
#   TITANIOPOS_JWT_SECRET — required for a working embedded JWT secret.
#   TITANIOPOS_DEVTOOLS_PASSWORD — optional; use when OPEN_DEVTOOLS_ON_START is
#     false so support staff can unlock DevTools on installed POS builds.
#
# The workflow generates `.env` before `npm run release`; do not commit `.env`.
# If TITANIOPOS_URL is missing in Variables, the build uses http://localhost:3001
# so you can spot a misconfigured pipeline in the installer.

# -----------------------------------------------------------------------------
# Auto-updates (electron-updater)
# -----------------------------------------------------------------------------
# The GitHub releases feed must be public, or release assets must be reachable
# without a token. Private repos often return 404 when the app checks for updates.

# Recommended: tag-driven release
#   git tag v1.0.1 && git push origin v1.0.1
# Latest installer links (after publishing a release):
#   https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Setup.exe
#   https://github.com/ospinosystems/electron-wrapper-titaniopos/releases/latest/download/TitanioPOS-Portable.exe

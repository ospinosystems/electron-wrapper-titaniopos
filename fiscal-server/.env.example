# Puerto del servidor fiscal (por defecto 3000)
FISCAL_SERVER_PORT=3000

# Ruta al ejecutable IntTFHKA.exe
# Prioridad de búsqueda: INTFHKA_PATH -> ./IntTFHKA.exe -> C:\IntTFHKA\IntTFHKA.exe
INTFHKA_PATH=C:\IntTFHKA\IntTFHKA.exe

# Nivel de logs Flask (opcional: DEBUG, INFO, WARNING, ERROR)
FLASK_ENV=production

# (Opcional) Variable para forzar directorio de datos
# DATA_DIR=C:\Users\<tu_usuario>\Documents\TitanioPOS-Fiscal

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node / dependencies
node_modules/
.pnp*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
dist/
out/
build/
release/
tmp/
temp/
.cache/
.parcel-cache/
*-unpacked/

# Electron packaging artifacts
*.AppImage
*.dmg
*.exe
*.msi
*.pkg
*.deb
*.rpm
*.snap
*.flatpak
*.asar
*.blockmap
*.zip

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Tests / coverage
coverage/

# TypeScript
*.tsbuildinfo

# Environment files
.env
.env.*
!.env.example

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
